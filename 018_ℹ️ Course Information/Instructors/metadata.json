  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Our Team</title>\n    <style>\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        body {\n            font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial, sans-serif;\n            background: #ffffff;\n            color: #333333;\n            line-height: 1.6;\n            padding: 0;\n        }\n\n        /* Header matching EdStem's clean style */\n        .header {\n            background: #ffffff;\n            border-bottom: 1px solid #e5e7eb;\n            padding: 48px 24px;\n            text-align: center;\n        }\n\n        .header h1 {\n            color: #111827;\n            font-size: 32px;\n            font-weight: 600;\n            margin-bottom: 8px;\n            letter-spacing: -0.02em;\n        }\n\n        .header p {\n            color: #6b7280;\n            font-size: 16px;\n            font-weight: 400;\n            max-width: 600px;\n            margin: 0 auto;\n        }\n\n        /* Container */\n        .container {\n            max-width: 1200px;\n            margin: 0 auto;\n            padding: 48px 24px;\n        }\n\n        /* Team grid */\n        .team-grid {\n            display: grid;\n            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));\n            gap: 32px;\n        }\n\n        /* Team member card - clean EdStem style */\n        .team-member {\n            background: #ffffff;\n            border: 1px solid #e5e7eb;\n            border-radius: 8px;\n            padding: 24px;\n            transition: all 0.2s ease;\n            height: 100%;\n            display: flex;\n            flex-direction: column;\n        }\n\n        .team-member:hover {\n            border-color: #d1d5db;\n            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);\n        }\n\n        /* Profile image container */\n        .profile-img-container {\n            width: 96px;\n            height: 96px;\n            margin: 0 auto 20px;\n            border-radius: 50%;\n            overflow: hidden;\n            background: #f3f4f6;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n        }\n\n        .profile-img {\n            width: 100%;\n            height: 100%;\n            object-fit: cover;\n        }\n\n        /* Placeholder initials when no image */\n        .profile-placeholder {\n            font-size: 32px;\n            font-weight: 600;\n            color: #6b7280;\n        }\n\n        /* Member name */\n        .member-name {\n            color: #111827;\n            font-size: 18px;\n            font-weight: 600;\n            text-align: center;\n            margin-bottom: 6px;\n        }\n\n        /* Member title - subtle purple like EdStem's highlights */\n        .member-role {\n            color: #7c3aed;\n            font-size: 13px;\n            font-weight: 500;\n            text-align: center;\n            margin-bottom: 16px;\n            text-transform: uppercase;\n            letter-spacing: 0.05em;\n        }\n\n        /* Member description */\n        .member-description {\n            color: #4b5563;\n            font-size: 14px;\n            line-height: 1.6;\n            flex-grow: 1;\n            margin-bottom: 20px;\n        }\n\n        /* LinkedIn link - EdStem style button */\n        .linkedin-link {\n            display: inline-flex;\n            align-items: center;\n            justify-content: center;\n            gap: 6px;\n            width: 100%;\n            padding: 8px 16px;\n            background: #ffffff;\n            color: #4b5563;\n            border: 1px solid #e5e7eb;\n            border-radius: 6px;\n            text-decoration: none;\n            font-size: 14px;\n            font-weight: 500;\n            transition: all 0.2s ease;\n        }\n\n        .linkedin-link:hover {\n            background: #f9fafb;\n            border-color: #d1d5db;\n            color: #111827;\n        }\n\n        .linkedin-link svg {\n            width: 16px;\n            height: 16px;\n        }\n\n        /* Responsive */\n        @media (max-width: 768px) {\n            .header h1 {\n                font-size: 28px;\n            }\n            \n            .team-grid {\n                grid-template-columns: 1fr;\n                gap: 24px;\n            }\n\n            .container {\n                padding: 32px 20px;\n            }\n        }\n\n        @media (min-width: 768px) and (max-width: 1024px) {\n            .team-grid {\n                grid-template-columns: repeat(2, 1fr);\n            }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"header\">\n        <h1>Our Team</h1>\n    </div>\n\n    <div class=\"container\">\n        <div class=\"team-grid\">\n            <!-- Pavlos Protopapas -->\n            <div class=\"team-member\">\n                <div class=\"profile-img-container\">\n                    <img src=\"https://raw.githubusercontent.com/vishnu701/worshop-assets/main/Pavlos.jpg\" alt=\"Pavlos Protopapas\" class=\"profile-img\">\n                </div>\n                <h3 class=\"member-name\">Pavlos Protopapas</h3>\n                <p class=\"member-role\">Educator & Researcher</p>\n                <p class=\"member-description\">\n                    Pavlos is an educator and researcher. Pavlos teaches CS109A, CS109B, Introduction to Data Science, and Advanced Topics in Data Science. He also teaches a course in MLOps. In the past, he has taught Capstone courses in Data Science and Computational Science, Introduction to Deep Reinforcement Learning, and a course in Physics-Informed Neural Networks. Besides teaching regular classes at Harvard, his courses are available via the Harvard Extension School and HarvardX. He has also participated in Data Science schools in Chile, Colombia, India, and Rwanda. His research lies at the intersection of astronomy, machine learning, and statistics. Most of his research activities are described on these pages.\n                </p>\n                <a href=\"https://www.stellardnn.org/people.html\" class=\"linkedin-link\" target=\"_blank\">\n                    <svg fill=\"currentColor\" viewBox=\"0 0 24 24\">\n                        <path d=\"M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.94-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z\"/>\n                    </svg>\n                    View StellarDNN\n                </a>\n            </div>\n\n            <!-- Chris Gumb -->\n            <div class=\"team-member\">\n                <div class=\"profile-img-container\">\n                    <img src=\"https://raw.githubusercontent.com/vishnu701/worshop-assets/main/Chris.jpg\" alt=\"Chris Gumb\" class=\"profile-img\">\n                </div>\n                <h3 class=\"member-name\">Chris Gumb</h3>\n                <p class=\"member-role\">Preceptor at Harvard SEAS</p>\n                <p class=\"member-description\">\n                    Chris Gumb is a preceptor at Harvard SEAS, where he designs course materials, teaches labs, and manages the teaching assistants for core courses in the Data Science and Computational Science and Engineering Master's programs. He has extensive experience creating and implementing hands-on assignments, coding challenges, and Kaggle competitions to engage students in applying machine learning and data science techniques to real-world problems.\n                </p>\n                <a href=\"https://seas.harvard.edu/person/chris-gumb\" class=\"linkedin-link\" target=\"_blank\">\n                    <svg fill=\"currentColor\" viewBox=\"0 0 24 24\">\n                        <path d=\"M12 3L1 9l4 2.18v6L12 21l7-3.82v-6l2-1.09V17h2V9L12 3zm6.82 6L12 12.72 5.18 9 12 5.28 18.82 9zM17 15.99l-5 2.73-5-2.73v-3.72L12 15l5-2.73v3.72z\"/>\n                    </svg>\n                    View Harvard Directory\n                </a>\n            </div>\n\n            <!-- Shivas Jayaram -->\n            <div class=\"team-member\">\n                <div class=\"profile-img-container\">\n                    <img src=\"https://raw.githubusercontent.com/vishnu701/worshop-assets/main/Shivas.png\" alt=\"Shivas Jayaram\" class=\"profile-img\">\n                </div>\n                <h3 class=\"member-name\">Shivas Jayaram</h3>\n                <p class=\"member-role\">Co-Founder & CTO at Instel</p>\n                <p class=\"member-description\">\n                    Shivas is Co-Founder & Chief Technology Officer at Instel. He is a highly experienced deep Learning researcher, educator, and practitioner with decades of experience as a solution architect and data scientist. He has spearheaded the design and management of numerous AI-driven solutions across the manufacturing and technology sectors.\n                </p>\n                <a href=\"https://www.linkedin.com/in/shivasj/\" class=\"linkedin-link\" target=\"_blank\">\n                    <svg fill=\"currentColor\" viewBox=\"0 0 24 24\">\n                        <path d=\"M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z\"/>\n                    </svg>\n                    View LinkedIn\n                </a>\n            </div>\n\n            <!-- Rashmi Banthia -->\n            <div class=\"team-member\">\n                <div class=\"profile-img-container\">\n                    <img src=\"https://raw.githubusercontent.com/vishnu701/worshop-assets/main/Rashmi.png\" alt=\"Rashmi Banthia\" class=\"profile-img\">\n                </div>\n                <h3 class=\"member-name\">Rashmi Banthia</h3>\n                <p class=\"member-role\">Data Scientist & Teaching Fellow</p>\n                <p class=\"member-description\">\n                    Rashmi is an accomplished Data Scientist with expertise in AI, Machine Learning, Deep Learning. Rashmi serves as a Teaching Fellow for Machine Learning and Data Science courses at Harvard Extension School, Harvard SEAS, and Harvard Business School. As a Kaggle Competitions Master, she has achieved remarkable success in many competitions.\n                </p>\n                <a href=\"https://www.linkedin.com/in/rashmibanthia\" class=\"linkedin-link\" target=\"_blank\">\n                    <svg fill=\"currentColor\" viewBox=\"0 0 24 24\">\n                        <path d=\"M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z\"/>\n                    </svg>\n                    View LinkedIn\n                </a>\n            </div>\n\n            <!-- Ignacio Becker -->\n            <div class=\"team-member\">\n                <div class=\"profile-img-container\">\n                    <img src=\"https://raw.githubusercontent.com/vishnu701/worshop-assets/main/Ignacio.png\" alt=\"Ignacio Becker\" class=\"profile-img\">\n                </div>\n                <h3 class=\"member-name\">Ignacio Becker</h3>\n                <p class=\"member-role\">Senior ML Engineer at CMPC</p>\n                <p class=\"member-description\">\n                    Ignacio is a former Computer Science Lecturer at the Harvard John A. Paulson School of Engineering and Applied Sciences. He holds a PhD in Computer Science from Pontificia Universidad Cat\u00f3lica in Chile, with a strong background in astronomy. He currently works as a Senior ML Engineer at CMPC, a cellulose-producing company in Chile.  His primary research intereat is on applying artificial intelligence to astrophysical problems. He is developing pipelines to process massive real-time data streams from next-generation telescopes.\n                </p>\n                <a href=\"https://www.linkedin.com/in/ignacio-becker/\" class=\"linkedin-link\" target=\"_blank\">\n                    <svg fill=\"currentColor\" viewBox=\"0 0 24 24\">\n                        <path d=\"M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z\"/>\n                    </svg>\n                    View LinkedIn\n                </a>\n            </div>\n\n            <!-- Shibani Budhraja -->\n            <div class=\"team-member\">\n                <div class=\"profile-img-container\">\n                    <img src=\"https://raw.githubusercontent.com/vishnu701/worshop-assets/main/Shibani.png\" alt=\"Shibani Budhraja\" class=\"profile-img\">\n                </div>\n                <h3 class=\"member-name\">Shibani Budhraja</h3>\n                <p class=\"member-role\">Chief Data Scientist</p>\n                <p class=\"member-description\">\n                    Shibani Budhraja went from studying brainwaves to teaching machines how to think. With a background in psychology and neuroscience, she now co-teaches deep learning and LLMs with Prof. Pavlos Protopapas and helps small companies build AI tools. When she's not immersed in data, you'll find her making music or spending time with her dog.\n                </p>\n                <a href=\"https://www.linkedin.com/in/shibanibudhraja/\" class=\"linkedin-link\" target=\"_blank\">\n                    <svg fill=\"currentColor\" viewBox=\"0 0 24 24\">\n                        <path d=\"M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z\"/>\n                    </svg>\n                    View LinkedIn\n                </a>\n            </div>\n\n                        <!-- Vishnu M -->\n            <div class=\"team-member\">\n                <div class=\"profile-img-container\">\n                    <img src=\"https://raw.githubusercontent.com/vishnu701/worshop-assets/main/Vishnu.png\" alt=\"Vishnu M\" class=\"profile-img\">\n                </div>\n                <h3 class=\"member-name\">Vishnu M</h3>\n                <p class=\"member-role\">Technologist & Entrepreneur</p>\n                <p class=\"member-description\">\n                    Vishnu is a technologist and an entrepreneur with expertise in applied machine learning and scalable product development. He is passionate about demystifying complex technologies and empowering the next generation of builders. His work focuses on creating accessible pathways into AI and technology, helping transform ambitious ideas into real-world solutions.\n                </p>\n                <a href=\"https://www.linkedin.com/in/vishnu701/\" class=\"linkedin-link\" target=\"_blank\">\n                    <svg fill=\"currentColor\" viewBox=\"0 0 24 24\">\n                        <path d=\"M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z\"/>\n                    </svg>\n                    View LinkedIn\n                </a>\n            </div>\n\n            <!-- Nawang Bhutia -->\n            <div class=\"team-member\">\n                <div class=\"profile-img-container\">\n                    <img src=\"https://raw.githubusercontent.com/vishnu701/worshop-assets/main/Nawang.png\" alt=\"Nawang Bhutia\" class=\"profile-img\">\n                </div>\n                <h3 class=\"member-name\">Nawang Bhutia</h3>\n                <p class=\"member-role\">Senior Data Scientist</p>\n                <p class=\"member-description\">\n                    Nawang Bhutia is a Senior Data Scientist at System 3 with a background in Information Science (B.E., 2022). He specializes in applying machine learning and deep learning techniques to build impactful, scalable AI solutions. Passionate about turning data into actionable insights and driving innovation through AI.\n                </p>\n                <a href=\"https://www.linkedin.com/in/nawang-thinley-bhutia-0158bb218/\" class=\"linkedin-link\" target=\"_blank\">\n                    <svg fill=\"currentColor\" viewBox=\"0 0 24 24\">\n                        <path d=\"M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z\"/>\n                    </svg>\n                    View LinkedIn\n                </a>\n            </div>\n\n            <!-- Anshika Gupta -->\n            <div class=\"team-member\">\n                <div class=\"profile-img-container\">\n                    <img src=\"https://raw.githubusercontent.com/vishnu701/worshop-assets/main/Anshika.png\" alt=\"Anshika Gupta\" class=\"profile-img\">\n                </div>\n                <h3 class=\"member-name\">Anshika Gupta</h3>\n                <p class=\"member-role\">AI Entrepreneur</p>\n                <p class=\"member-description\">\n                    Anshika is an AI enthusiast turned entrepreneur passionate about building AI ventures that scale into global success stories. She partners with experienced faculty to make premium education in AI accessible worldwide, creating pathways for students and professionals to explore frontier technologies. When not working, she's usually on a badminton court or fueling her coffee obsession.\n                </p>\n                <a href=\"https://www.linkedin.com/in/iamanshika/\" class=\"linkedin-link\" target=\"_blank\">\n                    <svg fill=\"currentColor\" viewBox=\"0 0 24 24\">\n                        <path d=\"M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z\"/>\n                    </svg>\n                    View LinkedIn\n                </a>\n            </div>\n        </div>\n    </div>\n</body>\n</html>"
}