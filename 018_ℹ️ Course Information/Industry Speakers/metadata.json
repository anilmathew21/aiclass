  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Industry Speakers</title>\n    <style>\n        * { margin: 0; padding: 0; box-sizing: border-box; }\n        body {\n            font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, \"Helvetica Neue\", Arial, sans-serif;\n            background: #ffffff; color: #333333; line-height: 1.6; padding: 0;\n        }\n        .header { background: #ffffff; border-bottom: 1px solid #e5e7eb; padding: 48px 24px; text-align: center; }\n        .header h1 { color: #111827; font-size: 32px; font-weight: 600; margin-bottom: 8px; letter-spacing: -0.02em; }\n\n        .container { max-width: 1200px; margin: 0 auto; padding: 48px 24px; }\n\n        .speaker-grid {\n            display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));\n            gap: 32px; max-width: 1100px; margin: 0 auto;\n        }\n\n        .speaker-card {\n            background: #ffffff; border: 1px solid #e5e7eb; border-radius: 8px; padding: 24px;\n            transition: all 0.2s ease; height: 100%; display: flex; flex-direction: column;\n        }\n        .speaker-card:hover { border-color: #d1d5db; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05); }\n\n        .profile-img-container {\n            width: 96px; height: 96px; margin: 0 auto 20px; border-radius: 50%; overflow: hidden;\n            background: #f3f4f6; display: flex; align-items: center; justify-content: center;\n        }\n        .profile-img { width: 100%; height: 100%; object-fit: cover; }\n\n        .speaker-name { color: #111827; font-size: 18px; font-weight: 600; text-align: center; margin-bottom: 6px; }\n        .speaker-role {\n            color: #7c3aed; font-size: 13px; font-weight: 500; text-align: center; margin-bottom: 16px;\n            text-transform: uppercase; letter-spacing: 0.05em;\n        }\n        .speaker-description { color: #4b5563; font-size: 14px; line-height: 1.6; flex-grow: 1; margin-bottom: 20px; }\n\n        .linkedin-link {\n            display: inline-flex; align-items: center; justify-content: center; gap: 6px; width: 100%;\n            padding: 8px 16px; background: #ffffff; color: #4b5563; border: 1px solid #e5e7eb; border-radius: 6px;\n            text-decoration: none; font-size: 14px; font-weight: 500; transition: all 0.2s ease;\n        }\n        .linkedin-link:hover { background: #f9fafb; border-color: #d1d5db; color: #111827; }\n        .linkedin-link svg { width: 16px; height: 16px; }\n\n        @media (max-width: 768px) {\n            .header h1 { font-size: 28px; }\n            .speaker-grid { grid-template-columns: 1fr; gap: 24px; }\n            .container { padding: 32px 20px; }\n        }\n        @media (min-width: 768px) and (max-width: 1024px) {\n            .speaker-grid { grid-template-columns: repeat(2, 1fr); }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"header\">\n        <h1>Industry Speakers</h1>\n    </div>\n\n    <div class=\"container\">\n        <div class=\"speaker-grid\">\n            <!-- Xiao-Li Meng (First) -->\n            <div class=\"speaker-card\">\n                <div class=\"profile-img-container\">\n                    <img src=\"https://ecos-appdev-production.s3.amazonaws.com/science_site/s3fs-public/inline-images/xlm-hires.jpg\"\n                         alt=\"Portrait of Xiao-Li Meng\"\n                         class=\"profile-img\">\n                </div>\n                <h3 class=\"speaker-name\">Xiao-Li Meng</h3>\n                <p class=\"speaker-role\">Whipple V. N. Jones Professor of Statistics, Harvard University</p>\n                <p class=\"speaker-description\">\n                    Professor Meng is a distinguished statistician and the founding Editor-in-Chief of the Harvard Data Science Review. \n                    He served as Dean of Harvard\u2019s Graduate School of Arts & Sciences (2012\u20132017) and Chair of the Department of Statistics (2004\u20132012). \n                    His work spans statistical inference and computation\u2014from Bayesian foundations to EM and MCMC\u2014and he received the COPSS Presidents\u2019 Award in 2001.\n                </p>\n                <a href=\"https://statistics.fas.harvard.edu/people/xiao-li-meng\" class=\"linkedin-link\" target=\"_blank\" rel=\"noopener\">\n                    <svg fill=\"currentColor\" viewBox=\"0 0 24 24\" aria-hidden=\"true\">\n                                    <path d=\"M14 3h7v7h-2V6.414l-9.293 9.293-1.414-1.414L17.586 5H14V3zM5 5h5V3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2v-5h-2v5H5V5z\"/>\n                    </svg>\n                    View Faculty Profile\n                </a>\n            </div>\n\n            <!-- Nicholas Stern -->\n            <div class=\"speaker-card\">\n                <div class=\"profile-img-container\">\n                    <img src=\"https://raw.githubusercontent.com/vishnu701/worshop-assets/main/Nicholas.png\" alt=\"Nicholas Stern\" class=\"profile-img\">\n                </div>\n                <h3 class=\"speaker-name\">Nicholas Stern</h3>\n                <p class=\"speaker-role\">Staff Data Scientist at LinkedIn</p>\n                <p class=\"speaker-description\">\n                    Nick Stern is a Staff Data Scientist at LinkedIn, where he leverages generative AI to evaluate and optimize the jobs marketplace.\n                    Prior to LinkedIn, Nick completed his M.S. in Data Science at Harvard\u2019s Institute for Applied Computational Science, researching computer vision applications in biomedical sciences.\n                </p>\n                <a href=\"https://www.linkedin.com/in/nzstern/\" class=\"linkedin-link\" target=\"_blank\" rel=\"noopener\">\n                    <svg fill=\"currentColor\" viewBox=\"0 0 24 24\" aria-hidden=\"true\">\n                        <path d=\"M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z\"/>\n                    </svg>\n                    View LinkedIn\n                </a>\n            </div>\n\n            <!-- Laura Kulowski -->\n            <div class=\"speaker-card\">\n                <div class=\"profile-img-container\">\n                    <img src=\"https://raw.githubusercontent.com/vishnu701/worshop-assets/main/Laura.png\" alt=\"Laura Kulowski\" class=\"profile-img\">\n                </div>\n                <h3 class=\"speaker-name\">Laura Kulowski</h3>\n                <p class=\"speaker-role\">Senior Applied Scientist at AWS</p>\n                <p class=\"speaker-description\">\n                    Laura Kulowski is a Senior Applied Scientist at the AWS Generative AI Innovation Center, where she partners with customers to build generative AI solutions.\n                    Before Amazon, Laura completed her PhD at Harvard\u2019s Department of Earth and Planetary Sciences, investigating Jupiter\u2019s deep zonal flows and magnetic field using Juno data.\n                </p>\n                <a href=\"https://www.linkedin.com/in/laurakulowski/\" class=\"linkedin-link\" target=\"_blank\" rel=\"noopener\">\n                    <svg fill=\"currentColor\" viewBox=\"0 0 24 24\" aria-hidden=\"true\">\n                        <path d=\"M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z\"/>\n                    </svg>\n                    View LinkedIn\n                </a>\n            </div>\n\n            <!-- Varshini -->\n            <div class=\"speaker-card\">\n                <div class=\"profile-img-container\">\n                    <img src=\"https://raw.githubusercontent.com/vishnu701/worshop-assets/main/Varshini.png\" alt=\"Varshini Reddy\" class=\"profile-img\">\n                </div>\n                <h3 class=\"speaker-name\">Varshini Reddy</h3>\n                <p class=\"speaker-role\">Research Scientist at Kensho</p>\n                <p class=\"speaker-description\">\n                    Varshini is a Data Science graduate from Harvard University. She is a Research Scientist at Kensho Technologies,\n                    exploring NLP applications at the intersection of language and finance. Outside of work, she enjoys baking and boxing.\n                </p>\n                <a href=\"https://www.linkedin.com/in/varshinireddy/\" class=\"linkedin-link\" target=\"_blank\" rel=\"noopener\">\n                    <svg fill=\"currentColor\" viewBox=\"0 0 24 24\" aria-hidden=\"true\">\n                        <path d=\"M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z\"/>\n                    </svg>\n                    View LinkedIn\n                </a>\n            </div>\n        \n            <!-- Adam Wiemerslage -->\n            <div class=\"speaker-card\">\n                <div class=\"profile-img-container\">\n                    <img src=\"https://raw.githubusercontent.com/vishnu701/worshop-assets/main/adam_kensho.jpeg\" alt=\"Adam Wiemerslage\" class=\"profile-img\">\n                </div>\n                <h3 class=\"speaker-name\">Adam Wiemerslage</h3>\n                <p class=\"speaker-role\">Research Scientist at Kensho</p>\n                <p class=\"speaker-description\">\n                    Adam Wiemerslage is a research scientist at Kensho, where he works on LLM evaluation and tokenization on the R&D team. He completed his PhD in computer science at the University of Colorado Boulder this past year, focusing on natural language processing. He resides in Boulder, Colorado.\n                </p>\n                <a href=\"https://www.linkedin.com/in/adam-wiemerslage-0a000775/\" class=\"linkedin-link\" target=\"_blank\" rel=\"noopener\">\n                    <svg fill=\"currentColor\" viewBox=\"0 0 24 24\" aria-hidden=\"true\">\n                        <path d=\"M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z\"/>\n                    </svg>\n                    View LinkedIn\n                </a>\n            </div>\n        </div>\n    </div>\n</body>\n</html>\n"
}